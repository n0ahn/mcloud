{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-path",
    "dialog:default",
    "shell:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-temp-read-recursive",
    "fs:allow-temp-write-recursive",
    "fs:scope-temp-recursive"
  ]
}